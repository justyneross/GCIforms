  100% { transform: perspective(1000px) rotateY(-90deg); opacity: 0; }
}

#vpt .transition.zoom.in { animation-name: zoomIn; }

#vpt .transition.zoom.out { animation-name: zoomOut; }

@keyframes zoomIn {=20
  0% { opacity: 1; transform: scale(0); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes zoomOut {=20
  0% { opacity: 1; transform: scale(1); }
  100% { opacity: 1; transform: scale(0); }
}

#vpt .flash.transition { animation-duration: 0.75s; animation-name: flash; =
}

#vpt .shake.transition { animation-duration: 0.75s; animation-name: shake; =
}

#vpt .bounce.transition { animation-duration: 0.75s; animation-name: bounce=
; }

#vpt .tada.transition { animation-duration: 0.75s; animation-name: tada; }

#vpt .pulse.transition { animation-duration: 0.5s; animation-name: pulse; }

#vpt .jiggle.transition { animation-duration: 0.75s; animation-name: jiggle=
; }

#vpt .transition.glow { animation-duration: 2s; animation-timing-function: =
cubic-bezier(0.19, 1, 0.22, 1); animation-name: glow; }

@keyframes flash {=20
  0%, 50%, 100% { opacity: 1; }
  25%, 75% { opacity: 0; }
}

@keyframes shake {=20
  0%, 100% { transform: translateX(0px); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10px); }
  20%, 40%, 60%, 80% { transform: translateX(10px); }
}

@keyframes bounce {=20
  0%, 20%, 50%, 80%, 100% { transform: translateY(0px); }
  40% { transform: translateY(-30px); }
  60% { transform: translateY(-15px); }
}

@keyframes tada {=20
  0% { transform: scale(1); }
  10%, 20% { transform: scale(0.9) rotate(-3deg); }
  30%, 50%, 70%, 90% { transform: scale(1.1) rotate(3deg); }
  40%, 60%, 80% { transform: scale(1.1) rotate(-3deg); }
  100% { transform: scale(1) rotate(0deg); }
}

@keyframes pulse {=20
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(0.9); opacity: 0.7; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes jiggle {=20
  0% { transform: scaleX(1); }
  30% { transform: scale3d(1.25, 0.75, 1); }
  40% { transform: scale3d(0.75, 1.25, 1); }
  50% { transform: scale3d(1.15, 0.85, 1); }
  65% { transform: scale3d(0.95, 1.05, 1); }
  75% { transform: scale3d(1.05, 0.95, 1); }
  100% { transform: scaleX(1); }
}

@keyframes glow {=20
  0% { background-color: rgb(252, 252, 253); }
  30% { background-color: rgb(255, 246, 205); }
  100% { background-color: rgb(252, 252, 253); }
}

